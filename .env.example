# Don't Be Shy — Environment variables
# Copy to .env.local and fill in values. Never commit .env or .env.local.

# Required ONLY if you want demo mode (server-side fallback when user hasn't set their own key).
# Most users provide their own Anthropic key in the UI (BYOK), so this is optional.
ANTHROPIC_API_KEY=

# Optional — Supabase persistence for cross-device session history.
# Leave blank to run with browser-local sessions only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — analytics, monitoring, etc. Add as needed.
